#Makefile for vamps
SHELL = /bin/sh

CC	= @CC@
CFLAGS	= @CFLAGS@

CINT =  ../src/main/*.c ../src/maq.lib/*.c\
DOC = ../doc/*.tex 
top_srcdir 	= @top_srcdir@
srcdir 		= @srcdir@
prefix 		= @prefix@
exec_prefix 	= @exec_prefix@
BINDIR	= @bindir@


clean:
	${RM} ${TRASH} mkidx mkinp slvsel report run pretop demo vampsfit sldoc

distclean: clean
